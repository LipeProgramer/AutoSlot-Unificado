# ──────────────────────────────────────────
# AutoSlot — variáveis de ambiente de exemplo
# Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────

# ── FRONT-END (frontend/.env) ─────────────
# URL base da API do back-end
VITE_API_URL=http://localhost:5000/api

# ── BACK-END (backend/AutoSlot (API)/appsettings.json) ────
# String de conexão com o PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autoslot
DB_USER=postgres
DB_PASSWORD=SUA_SENHA_AQUI

# Chave secreta para geração dos tokens JWT (mínimo 32 caracteres)
JWT_KEY=troque-esta-chave-por-algo-seguro-com-32-chars
JWT_ISSUER=AutoSlot
