# ──────────────────────────────────────────
# AutoSlot — variáveis de ambiente de exemplo
# Copie este arquivo para .env e preencha os valores reais
# ──────────────────────────────────────────

# ── FRONT-END (frontend/.env) ─────────────
# URL base da API do back-end
VITE_API_URL=https://autoslot-unificado-production.up.railway.app

# ── BACK-END (backend/AutoSlot (API)/appsettings.json) ────
# String de conexão com o PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=autoslot
DB_USER=postgres
DB_PASSWORD=autoslotsupabase

# Chave secreta para geração dos tokens JWT (mínimo 32 caracteres)
JWT_KEY=254b5176-2172-4878-bbde-02337dd766e2
JWT_ISSUER=AutoSlot
